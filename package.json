{
  "name": "B1EnterpriceApplication-cds",
  "version": "1.0.0",
  "devDependencies": {
    "@sap/cds-dk": "^9.7.2",
    "@ui5/cli": "^4.0.57",
    "mbt": "^1.2.49",
    "rimraf": "^5.0.5"
  },
  "sapux": [
    "app/businesspartners",
    "app/item_master",
    "app/purchase_order",
    "app/businesspartners",
    "app/item_master",
    "app/purchase_order",
    "app/purchaseorder_analytics"
  ],
  "scripts": {
