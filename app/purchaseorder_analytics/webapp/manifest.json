{
  "_version": "1.85.0",
  "sap.app": {
    "id": "purchaseorderanalytics",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:alp",
      "version": "1.27.0",
      "toolsId": "90384a3e-0009-494d-8e7a-63ee0fe1c05f"
    },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/service/Purchase_Analytics/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.0"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "PurchaseOrder_Analytics-managepo_analytics": {
          "semanticObject": "PurchaseOrder_Analytics",
          "action": "managepo_analytics",
          "title": "{{PurchaseOrder_Analytics-managepo_analytics.flpTitle}}",
          "subTitle": "{{PurchaseOrder_Analytics-managepo_analytics.flpSubtitle}}",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.149.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "purchaseorderanalytics.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "PurchaseOrdersAnalyticsList",
          "target": "PurchaseOrdersAnalyticsList"
        },
        {
          "pattern": "PurchaseOrdersAnalytics({key}):?query:",
          "name": "PurchaseOrdersAnalyticsObjectPage",
          "target": "PurchaseOrdersAnalyticsObjectPage"
        }
      ],
      "targets": {
        "PurchaseOrdersAnalyticsList": {
          "type": "Component",
          "id": "PurchaseOrdersAnalyticsList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/PurchaseOrdersAnalytics",
              "variantManagement": "Page",
              "navigation": {
                "PurchaseOrdersAnalytics": {
                  "detail": {
                    "route": "PurchaseOrdersAnalyticsObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "AnalyticalTable",
                    "selectionMode": "Multi"
                  }
                }
              },
              "views": {
                "paths": [
                  {
                    "primary": [
                      {
                        "annotationPath": "com.sap.vocabularies.UI.v1.PresentationVariant"
                      }
                    ],
                    "secondary": [
                      {
                        "annotationPath": "com.sap.vocabularies.UI.v1.LineItem"
                      }
                    ],
                    "defaultPath": "both"
                  }
                ]
              }
            }
          }
        },
        "PurchaseOrdersAnalyticsObjectPage": {
          "type": "Component",
          "id": "PurchaseOrdersAnalyticsObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/PurchaseOrdersAnalytics"
            }
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "analytical"
  },
  "sap.fe": {
    "app": {
      "enableLazyLoading": true
    }
  }
}
